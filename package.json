{
  "name": "nanakay",
  "private": true,
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "install:all": "npm install && npm install --prefix frontend",
    "dev": "concurrently -n backend,frontend -c cyan,magenta \"node --watch index.js\" \"npm run dev --prefix frontend\"",
    "build": "npm run build --prefix frontend",
    "start": "npm run build && node index.js"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "nodemailer": "^9.0.3"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
